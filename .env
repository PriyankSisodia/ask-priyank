# Copy to deploy/.env for local runs (never commit real secrets).

GEMINI_API_KEY=
# GOOGLE_API_KEY=

CHAT_MODEL=gemini-2.5-flash-lite
TWIN_DISPLAY_NAME=Priyank Sisodia

# --- Twin text (keep off GitHub): merged in order Sheet → URL → env → local files ---
# Optional cache TTL when using Sheet/URL (seconds)
# CONTEXT_CACHE_SECONDS=120

# Google Sheet tab "twin_context" columns key | value (rows: summary, resume)
# GOOGLE_SHEET_ID=
# GSPREAD_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Or fetch JSON {"summary":"...","resume":"..."} or plain text with ---RESUME--- split
# CONTEXT_URL=

# Or paste text here (Render dashboard secrets for production)
# TWIN_SUMMARY=
# TWIN_RESUME_TEXT=

# Local dev only: read ../summary.txt and ../priyank_sisodia.pdf
# ALLOW_LOCAL_CONTEXT_FILES=1
